<script is:inline>
  // Anatomy hover sync: hovering a row highlights the matching SVG part.
  (function () {
    const rows = document.querySelectorAll(".anatomy-row");
    const parts = document.querySelectorAll(".anatomy-art .part");
    if (!rows.length || !parts.length) return;

    function clearAll() {
      rows.forEach((r) => r.classList.remove("is-active"));
      parts.forEach((p) => p.classList.remove("is-active"));
    }
    function activate(label) {
      rows.forEach((r) => r.classList.toggle("is-active", r.dataset.target === label));
      parts.forEach((p) => p.classList.toggle("is-active", p.dataset.label === label));
    }
    rows.forEach((r) => {
      r.addEventListener("mouseenter", () => activate(r.dataset.target));
      r.addEventListener("mouseleave", clearAll);
    });
    parts.forEach((p) => {
      p.addEventListener("mouseenter", () => activate(p.dataset.label));
      p.addEventListener("mouseleave", clearAll);
    });
  })();
</script>
