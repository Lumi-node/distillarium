---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Distill any task into a pocket-sized Spirit. Pure model. No API.",
  ogImage = "/og-default.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.svg" />
  <meta name="theme-color" content="#1a1208" />

  <!-- OpenGraph / social cards -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

  <meta name="generator" content={Astro.generator} />
</head>
<body>
  <nav class="site-nav">
    <a href="/" class="logo pixel-h"><span class="flask">⚗</span> THE DISTILLERY</a>
    <div class="nav-links">
      <a href="/why">Why</a>
      <a href="/how">How</a>
      <a href="/use-cases">Use cases</a>
      <a href="/cellar">Cellar</a>
      <a href="/glossary">Glossary</a>
      <a href="/docs">Docs</a>
      <a href="https://github.com/Lumi-node/distillarium" target="_blank" rel="noopener">GitHub</a>
    </div>
  </nav>

  <slot />

  <footer>
    <p>© 2026 The Distillery · <a href="https://github.com/Lumi-node/distillarium">GitHub</a> · <a href="/docs">Docs</a></p>
    <p style="margin-top:8px; opacity:0.75;">
      A lab from <a href="https://automate-capture.com" target="_blank" rel="noopener">automate-capture.com</a> ·
      Built on top of the <a href="https://research.automate-capture.com" target="_blank" rel="noopener">Research Radar</a> pipeline ·
      MIT licensed
    </p>
  </footer>
</body>
</html>
